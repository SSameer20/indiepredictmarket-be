# Required connection parameters
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Blockchain Configuration (Polygon Mainnet or Amoy/Mumbai testnet)
POLYGON_RPC_URL="https://polygon-rpc.com"

# The Admin wallet private key (NEVER COMMIT THIS FILE)
PRIVATE_KEY="0xYourAdminWalletPrivateKeyDoNotShare"

# The public address derived from PRIVATE_KEY above
ADMIN_WALLET_ADDRESS="0xYourAdminWalletPublicAddress"

# If using USDC on Polygon, put contract address here
USDC_CONTRACT_ADDRESS="0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359"

# Security
ADMIN_SECRET="super-secret-admin-key-for-creating-markets"
PORT=3000
