// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id            String        @id @default(uuid())
  walletAddress String        @unique
  // Phase 8: Float → Decimal for accurate financial calculations
  balance       Decimal       @default(0) @db.Decimal(18, 6)
  bets          Bet[]
  transactions  Transaction[]
}

model Market {
  id        String   @id @default(uuid())
  title     String
  endTime   DateTime
  resolved  Boolean  @default(false)
  outcome   Boolean?
  bets      Bet[]
}

model Bet {
  id        String   @id @default(uuid())
  userId    String
  marketId  String
  // Phase 8: Float → Decimal for precise bet amounts
  amount    Decimal  @db.Decimal(18, 6)
  side      String

  user      User     @relation(fields: [userId], references: [id])
  market    Market   @relation(fields: [marketId], references: [id])
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  txHash    String   @unique
  type      String   // "DEPOSIT" | "WITHDRAW"
  // Phase 8: Float → Decimal for precise tx amounts
  amount    Decimal  @db.Decimal(18, 6)
  status    String   // "CONFIRMED" | "PENDING" | "FAILED"
  // Phase 8 Multi-token: which token was used (e.g., "MATIC", "USDC")
  token     String   @default("MATIC")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
